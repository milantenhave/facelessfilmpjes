# ===========================================================================
# facelessfilmpjes - environment variables
# Copy this file to `.env` and fill in the values you want to use.
# Every provider is OPTIONAL. If a key is missing, the pipeline falls back
# to the built-in offline/template generators so the system still works.
# ===========================================================================

# --- LLM providers (choose any one; the first non-empty wins) -----------
LLM_PROVIDER=template          # template | openai | anthropic | ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Stock footage (free APIs) -----------------------------------------
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- TTS ----------------------------------------------------------------
# coqui | pyttsx3 | espeak  (coqui has best quality, pyttsx3 is lightest)
TTS_ENGINE=pyttsx3
COQUI_MODEL=tts_models/en/ljspeech/tacotron2-DDC

# --- Runtime ------------------------------------------------------------
LOG_LEVEL=INFO
OUTPUT_DIR=./videos
CACHE_DIR=./.cache
