# ===========================================================================
# facelessfilmpjes - environment variables
# Copy this file to `.env` and fill in the values you want to use.
#
# IMPORTANT: put comments on their own line. systemd's EnvironmentFile does
# NOT strip inline "# ..." from values, so `KEY=value # comment` will set
# the value to literally "value # comment".
# ===========================================================================

# --- Dashboard auth -----------------------------------------------------
# Password for the /login page. If empty, auth is disabled (dev only).
DASHBOARD_PASSWORD=change-me-please
SESSION_SECRET=generate-a-long-random-string

# Public base URL the web app is reachable at (used for OAuth callbacks
# and so Creatomate can fetch voice-over files).
# Local / SSH tunnel:  http://localhost:8000
# VPS direct:          http://YOUR.VPS.IP:8000
# Production:          https://faceless.yourdomain.tld
PUBLIC_BASE_URL=http://localhost:8000

# --- LLM ---------------------------------------------------------------
# Pick one. Anthropic recommended for script quality.
# Values: anthropic | openai | ollama | template
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional alternative providers:
OPENAI_MODEL=gpt-4o-mini
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# --- OpenAI (used for both LLM and TTS when enabled) --------------------
OPENAI_API_KEY=

# --- TTS ----------------------------------------------------------------
# "openai" uses OpenAI TTS HD (recommended).
# "local" forces pyttsx3/espeak/silent fallback (dev only).
TTS_ENGINE=openai
# Voices: alloy | echo | fable | onyx | nova | shimmer | ash | sage | verse
OPENAI_TTS_VOICE=nova
# Models: tts-1 (cheap) or tts-1-hd (better)
OPENAI_TTS_MODEL=tts-1-hd

# --- Video rendering (cloud) -------------------------------------------
# Creatomate renders pro videos with animated captions on their servers.
CREATOMATE_API_KEY=

# --- Stock footage ------------------------------------------------------
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- YouTube OAuth (Google Cloud project) -------------------------------
# 1. Google Cloud -> enable "YouTube Data API v3"
# 2. Create OAuth2 credentials, type "Web application"
# 3. Authorized redirect URI must match PUBLIC_BASE_URL + /oauth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Runtime ------------------------------------------------------------
LOG_LEVEL=INFO
OUTPUT_DIR=./videos
CACHE_DIR=./.cache
FACELESS_DB=./data/faceless.db
