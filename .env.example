# ===========================================================================
# facelessfilmpjes - environment variables
# Copy this file to `.env` and fill in the values you want to use.
# ===========================================================================

# --- Dashboard auth -----------------------------------------------------
# Password for the /login page. If empty, auth is disabled (dev only).
DASHBOARD_PASSWORD=change-me-please
SESSION_SECRET=generate-a-long-random-string

# Public base URL the web app is reachable at — used for OAuth callbacks
# and for Creatomate to fetch voice-over files.
# Local/SSH tunnel:   http://localhost:8000
# Production:         https://faceless.yourdomain.nl
PUBLIC_BASE_URL=http://localhost:8000

# --- LLM ---------------------------------------------------------------
# Pick one. Anthropic recommended for script quality.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional alternatives:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# --- TTS ----------------------------------------------------------------
# "openai" uses OpenAI TTS HD (recommended). Set TTS_ENGINE=local to force
# the pyttsx3/espeak/silent fallback.
TTS_ENGINE=openai
OPENAI_TTS_VOICE=nova            # alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_MODEL=tts-1-hd        # tts-1 (cheap) | tts-1-hd (better)

# --- Video rendering (cloud) -------------------------------------------
# Creatomate renders pro-style videos with animated captions in the cloud.
CREATOMATE_API_KEY=

# --- Stock footage ------------------------------------------------------
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- YouTube OAuth (Google Cloud project) -------------------------------
# 1. Create a Google Cloud project, enable "YouTube Data API v3".
# 2. Create OAuth2 credentials, type "Web application".
# 3. Authorized redirect URI must match PUBLIC_BASE_URL + /oauth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Runtime ------------------------------------------------------------
LOG_LEVEL=INFO
OUTPUT_DIR=./videos
CACHE_DIR=./.cache
FACELESS_DB=./data/faceless.db
